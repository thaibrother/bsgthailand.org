<style>
  .net-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:22px; margin:30px 0 36px; }
  .net-card { background:#fff; border:1px solid var(--border, #e6e1d6); border-radius:12px; padding:24px 22px; transition:border-color 0.2s; }
  .net-card:hover { border-color: var(--gold, #c9a74e); }
  .net-icon { font-size:28px; margin-bottom:10px; }
  .net-card h4 { font-family:'Cinzel', Georgia, serif; font-size:1.05em; letter-spacing:1px; color:var(--navy); margin:0 0 10px; }
  .net-card p { font-size:0.93em; line-height:1.6; color:var(--text-light); margin-bottom:14px; }
  .net-card a { font-size:0.88em; color:var(--navy); text-decoration:none; font-weight:600; letter-spacing:0.5px; }
  .net-card a:hover { color:var(--gold, #c9a74e); }
  .province-block { text-align:center; margin-top:34px; }
  .province-block h4 { font-family:'Inter',sans-serif; font-weight:600; font-size:13px; color:var(--navy); letter-spacing:1.5px; margin-bottom:14px; }
  .province-tags { display:flex; flex-wrap:wrap; justify-content:center; gap:8px; max-width:860px; margin:0 auto; }
  .prov-tag { display:inline-block; padding:7px 14px; background:#fff; border:1px solid var(--border, #e6e1d6); border-radius:20px; font-size:0.86em; color:var(--text-light); text-decoration:none; transition:all 0.2s; }
  .prov-tag:hover { border-color:var(--gold, #c9a74e); color:var(--navy); }
  .prov-tag.self { background:var(--navy); color:#fff; border-color:var(--navy); font-weight:600; }
</style>
</head>

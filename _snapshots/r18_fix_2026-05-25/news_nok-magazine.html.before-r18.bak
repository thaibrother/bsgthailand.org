<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NOK Magazine · News · Brothers of Saint Gabriel · Thailand Province</title>
<meta name="description" content="NOK Magazine — the long-standing publication of the Brothers of Saint Gabriel, Thailand Province. News from the communities, accounts of apostolic life, and the unbroken voice of the houses across many decades.">
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Playfair+Display:wght@400;600;700;900&family=EB+Garamond:wght@400;500;600;700&family=Inter:wght@300;400;500;600&family=Sarabun:wght@300;400;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="../assets/css/style.css">
<style>
  /* NOK Magazine — vintage masthead overlay */
  .nok-paper { background: #f4ecd8; color: #2a2218; padding: 60px 24px 80px; border-top: 6px double #2a2218; border-bottom: 6px double #2a2218; margin: 30px 0 40px; }
  .nok-inner { max-width: 880px; margin: 0 auto; }
  .nok-masthead { text-align: center; border-bottom: 3px solid #2a2218; padding-bottom: 22px; margin-bottom: 36px; }
  .nok-masthead .kicker { font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: 0.95em; letter-spacing: 6px; color: #5a4a2a; margin-bottom: 8px; text-transform: uppercase; }
  .nok-masthead h2 { font-family: 'Playfair Display', Georgia, serif; font-weight: 900; font-size: clamp(2.6em, 7vw, 4.4em); color: #2a2218; letter-spacing: 12px; line-height: 1; margin: 0; border: 0; padding: 0; }
  .nok-masthead .line { display: none; }
  .nok-masthead .rule { display: flex; align-items: center; justify-content: center; gap: 14px; margin-top: 18px; font-family: 'EB Garamond', serif; font-style: italic; color: #5a4a2a; font-size: 0.95em; }
  .nok-masthead .rule::before, .nok-masthead .rule::after { content: ''; flex: 0 0 80px; height: 1px; background: #5a4a2a; }
  .nok-tagline { font-family: 'EB Garamond', Georgia, serif; font-style: italic; text-align: center; color: #5a4a2a; font-size: 1.05em; margin-bottom: 36px; line-height: 1.6; }
  .nok-body { font-family: 'EB Garamond', Georgia, serif; font-size: 1.06em; line-height: 1.8; color: #2a2218; column-count: 1; }
  @media (min-width: 760px) { .nok-body.two-col { column-count: 2; column-gap: 40px; } }
  .nok-body p { margin-bottom: 14px; text-align: justify; hyphens: auto; }
  .nok-body p:first-of-type::first-letter { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 3.2em; float: left; line-height: 0.9; padding: 6px 8px 0 0; color: #6a3a14; }
  .nok-section-title { font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 1.4em; color: #2a2218; margin: 30px 0 14px; text-align: center; letter-spacing: 2px; text-transform: uppercase; column-span: all; }
  .nok-section-title::before, .nok-section-title::after { content: ' ✦ '; color: #a07a3a; font-weight: 400; }
  .nok-house { font-family: 'EB Garamond', serif; margin: 16px 0; padding-left: 12px; border-left: 2px solid #a07a3a; }
  .nok-house .place { font-style: italic; color: #5a4a2a; font-size: 0.92em; }
  .nok-house .text { color: #2a2218; font-size: 1em; margin-top: 4px; }
</style>
<script defer src="/assets/js/rome-cal.js"></script>
</head>
<body>
